model Role {
  id          String    @id @default(uuid())
  name        String
  description String?   @db.Text
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users       User[]
  permissions Permission[]

  @@map("roles")
}
